# ─────────────────────────────────────────────────────────────
# DGEC Gateway – Environment Variables
# Copy to .env and fill in real values. Never commit .env!
# ─────────────────────────────────────────────────────────────

# ── Frontend (Vite) ──────────────────────────────────────────
# Cloudflare Worker API base URL
VITE_API_BASE_URL=https://dgec-contact-api.dgroupofficial.workers.dev

# Supabase project credentials (public/anon key is safe to expose)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth redirect (must match Supabase Auth > URL Configuration)
VITE_SITE_URL=https://dgroupeducation.com

# ── Backend / Cloudflare Worker ──────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage
STORAGE_BUCKET=documents

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="DGEC <no-reply@dgroup.edu.np>"
ADMIN_EMAIL=info@dgroup.edu.np
FOUNDER_EMAIL=founder@dgroup.edu.np

# ── API Security ─────────────────────────────────────────────
ADMIN_API_TOKEN=change-this-to-a-strong-secret-token
ALLOWED_ORIGINS=https://dgroupeducation.com,https://www.dgroupeducation.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=8
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=5

# ── CI/CD (set in GitHub Actions Secrets) ───────────────────
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
