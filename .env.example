# ─────────────────────────────────────────────────────────────
# DGEC Gateway – Environment Variables
# Copy to .env and fill in real values. Never commit .env!
# ─────────────────────────────────────────────────────────────

# ── Frontend (Vite) ──────────────────────────────────────────
# Cloudflare Worker API base URL
VITE_API_BASE_URL=https://dgec-contact-api.dgroupofficial.workers.dev

# Supabase project credentials (public/anon key is safe to expose)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth redirect (must match Supabase Auth > URL Configuration)
VITE_SITE_URL=https://dgroupeducation.com

# Cloudflare Turnstile (spam protection). Get keys at dash.cloudflare.com → Turnstile.
# Leave blank to disable Turnstile in local development.
# Test site key (always-pass): 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=

# ── Backend / Cloudflare Worker ──────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage
STORAGE_BUCKET=documents

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM="DGEC <noreply@dgroupeducation.com>"
ADMIN_EMAIL=info@dgroupeducation.com
FOUNDER_EMAIL=founder@dgroupeducation.com
SITE_URL=https://dgroupeducation.com

# ── API Security ─────────────────────────────────────────────
ADMIN_API_TOKEN=change-this-to-a-strong-secret-token
# Turnstile secret key (set as Worker secret, NOT as [vars] in wrangler.toml).
# Test secret (always-pass): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=
ALLOWED_ORIGINS=https://dgroupeducation.com,https://www.dgroupeducation.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=8
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=5

# ── CI/CD (set in GitHub Actions Secrets) ───────────────────
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
